# ── Postgres (Neon) ──────────────────────────────────────────────────────────
# Copy the "Connection string" from your Neon project dashboard.
# It looks like:  postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# ── JWT ──────────────────────────────────────────────────────────────────────
# Paste any long random string here (40+ characters). Never commit the real value.
JWT_SECRET=change_me_to_a_long_random_secret_string

# ── Server ───────────────────────────────────────────────────────────────────
PORT=5000
